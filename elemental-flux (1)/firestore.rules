rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable) - The user's unique ID
    //   - gold: number (required) - The amount of gold the user has
    //   - inventory: map (required) - A map of card IDs to the quantity owned
    //   - discoveredRecipes: list (required) - A list of recipe IDs the user has discovered
    //   - deck: list (required) - A list of card IDs in the user's active deck
    //   - updatedAt: timestamp (required) - The last time the profile was updated
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the resource (for user-owned documents)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Verify UID hasn't been tampered with on create
    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }
    
    // Ensure uid field is not modified on update
    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }
    
    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserProfile() {
      return hasRequiredFields(['uid', 'gold', 'inventory', 'discoveredRecipes', 'deck', 'updatedAt']) &&
             hasOnlyAllowedFields(['uid', 'gold', 'inventory', 'discoveredRecipes', 'deck', 'updatedAt', 'upgrades']) &&
             request.resource.data.uid is string &&
             request.resource.data.gold is number &&
             request.resource.data.gold >= 0 &&
             request.resource.data.inventory is map &&
             request.resource.data.discoveredRecipes is list &&
             request.resource.data.discoveredRecipes.size() <= 500 &&
             request.resource.data.deck is list &&
             request.resource.data.deck.size() <= 60 &&
             (!('upgrades' in request.resource.data) || request.resource.data.upgrades is map) &&
             request.resource.data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && uidUnchanged() && isValidUserProfile();
      allow update: if isOwner(userId) && uidNotModified() && isValidUserProfile();
      allow delete: if false;
    }
  }
}
